# Copy to .env and adjust for your environment.

ENVIRONMENT=development

# IMPORTANT: change this in production
SECRET_KEY=CHANGE_ME_super_secret_key_for_jwt_signing_prabhu_capital
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# Default administrator (created on first run)
ADMIN_EMAIL=admin@prabhucapital.com
ADMIN_PASSWORD=Admin@123
ADMIN_NAME=League Administrator

# Database (SQLite by default)
# DATABASE_URL=sqlite:///./database/worldcup.db

# CORS — for LAN access list your machine IP, e.g.:
# BACKEND_CORS_ORIGINS=http://localhost:3000,http://192.168.1.25:3000
BACKEND_CORS_ORIGINS=*

# Scheduler / scraper
SCHEDULER_ENABLED=true
SCHEDULER_INTERVAL_MINUTES=15
SCRAPER_ENABLED=true
SPORTSDB_API_KEY=123
SPORTSDB_LEAGUE_ID=4429
SPORTSDB_SEASON=2025-2026
# Only auto-add fixtures that are still in the future (keeps already-finished
# games out of a league that starts mid-tournament). Set false to import history too.
SPORTSDB_INGEST_FUTURE_ONLY=true

# Payment
ENTRY_FEE=1000
